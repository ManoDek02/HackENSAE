# ============================================================
#  HackENSAE — Variables d'environnement
#  Copier ce fichier en .env et renseigner les valeurs
# ============================================================

# ── Neon PostgreSQL ───────────────────────────────────────────
# Récupérer depuis : console.neon.tech → votre projet → Connect
#
# IMPORTANT : utiliser la connection string POOLÉE (avec -pooler dans le hostname)
# Elle ressemble à :
#   postgresql://user:pwd@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
#
# La string DIRECTE (sans -pooler) est uniquement pour Alembic (migrations).
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require

# Connection directe pour Alembic (migrations uniquement)
DATABASE_URL_DIRECT=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── JWT ───────────────────────────────────────────────────────
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changez-moi-en-production

# Durée de validité des tokens en minutes (défaut : 60)
TOKEN_EXPIRE_MIN=60

# ── CORS ─────────────────────────────────────────────────────
# Origines autorisées (séparées par virgule)
# En développement : http://localhost:8000
# En production : https://votre-domaine.onrender.com
ALLOWED_ORIGINS=http://localhost:8000

# ── Debug ─────────────────────────────────────────────────────
# Afficher les requêtes SQL dans les logs (dev uniquement)
DB_ECHO=false
